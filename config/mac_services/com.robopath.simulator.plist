<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  ROBO-Path 헤드리스 시뮬레이터용 launchd LaunchAgent (사용자 레벨, sudo 불필요).

  배포 시 deploy-to-mac.yml 이 __HOME__ 플레이스홀더를 실제 $HOME 으로 치환하여
  ~/Library/LaunchAgents/com.robopath.simulator.plist 로 설치한다.

  - RunAtLoad: 로드되면 즉시 실행 (재부팅/로그인 시 자동 시작)
  - KeepAlive: 프로세스가 죽으면 자동 재시작
  - ThrottleInterval: 즉시 재크래시 루프 방지(최소 재시작 간격 초)
  주의: GUI 세션이 로그인된 상태여야 gui 도메인에서 동작한다.
-->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.robopath.simulator</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>__HOME__/ROBO-Path_project/scripts/run_simulator.sh</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>ThrottleInterval</key>
    <integer>15</integer>

    <key>WorkingDirectory</key>
    <string>__HOME__/ROBO-Path_project</string>

    <key>StandardOutPath</key>
    <string>__HOME__/ROBO-Path_project/logs/launchd-simulator.out.log</string>

    <key>StandardErrorPath</key>
    <string>__HOME__/ROBO-Path_project/logs/launchd-simulator.err.log</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>ROBOPATH_ROOT</key>
        <string>__HOME__/ROBO-Path_project</string>
    </dict>
</dict>
</plist>
